{
  "mcpServers": {
    "ha-mcp": {
      "command": "uvx",
      "args": ["ha-mcp@7.2.0"],
      "env": {
        "HOMEASSISTANT_URL": "${HA_URL}",
        "HOMEASSISTANT_TOKEN": "${HA_TOKEN}",
        "ENABLE_SKILLS": "true",
        "ENABLE_SKILLS_AS_TOOLS": "true",
        "ENABLE_TOOL_SEARCH": "true",
        "ENABLE_WEBSOCKET": "true"
      }
    }
  }
}
